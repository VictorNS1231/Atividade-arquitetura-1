FS = 44100  # sample rate


# Motivo "clássico" de 5 notas (audível e com cara de chamada/resposta).
# Você pode ajustar depois se quiser "mais parecido" ao seu ouvido.
THEME_5 = [262, 330, 392, 523, 784]  # C4, E4, G4, C5, G5


def sine_tone(freq_hz: float, dur_s: float, volume: float = 0.35) -> np.ndarray:
    t = np.linspace(0, dur_s, int(FS * dur_s), endpoint=False)
    wave = np.sin(2 * np.pi * freq_hz * t)

     # Envelope simples (ataque/decay) para ficar menos "beep"
    attack = int(0.015 * FS)
    release = int(0.030 * FS)
    env = np.ones_like(wave)
    if attack > 0:
        env[:attack] = np.linspace(0, 1, attack)
    if release > 0:
        env[-release:] = np.linspace(1, 0, release)

    return (volume * wave * env).astype(np.float32)

def play_freq(freq_hz: float, dur_s: float = 0.28, volume: float = 0.35):
    audio = sine_tone(freq_hz, dur_s, volume)
    sd.play(audio, FS)
    sd.wait()

def clamp(x, lo, hi):
    return max(lo, min(hi, x))

def semitone_shift(freq: float, semitones: int) -> float:
    # Temperamento igual: 12 semitons por oitava
    return freq * (2 ** (semitones / 12))


def play_theme_5(dur_s=0.35, gap_s=0.10, volume=0.35):
    for f in THEME_5:
        play_freq(f, dur_s, volume)
        time.sleep(gap_s)


def play_hex_as_close_encounters(hex_str: str, dur_s=0.28, gap_s=0.08, volume=0.35):
    """
    Estratégia "filme":
    - O motivo tem 5 notas base.
    - Cada dígito hex escolhe qual nota base (posição i%5)
    - E aplica um desvio em semitons baseado no valor 0..15
      (cria 'frases' com o mesmo DNA do motivo)
    """
    s = hex_str.strip().upper()

    if len(s) == 0:
        raise ValueError("Digite algum código hexadecimal.")
    if any(c not in "0123456789ABCDEF" for c in s):
        raise ValueError("Use apenas dígitos hexadecimais.")
    if len(s) > 64:
        raise ValueError("Limite de 64 dígitos.")

    for i, ch in enumerate(s):
        v = int(ch, 16)
        base = THEME_5[i % 5]

        # Mapeia 0..15 para um deslocamento musical agradável:
        # -6 .. +9 semitons (uma faixa boa e "expressiva")
        shift = v - 6

        f = semitone_shift(base, shift)
        f = clamp(f, 180, 2000) # garante audível e confortável

        play_freq(f, dur_s, volume)
        time.sleep(gap_s)


# Gera o áudio completo (para WAV), mesmo código do play_hex, mas sem tocar e que armazena o som gerado
def hex_to_audio_array(hex_str: str, dur_s=0.28, gap_s=0.08, volume=0.35) -> np.ndarray:
    s = hex_str.strip().upper()

    if len(s) == 0:
        raise ValueError("Digite algum código hexadecimal.")
    if any(c not in "0123456789ABCDEF" for c in s):
        raise ValueError("Use apenas dígitos hexadecimais.")
    if len(s) > 64:
        raise ValueError("Limite de 64 dígitos.")

    parts = []

    for i, ch in enumerate(s):
        v = int(ch, 16)
        base = THEME_5[i % 5]
        shift = v - 6
        f = semitone_shift(base, shift)
        f = clamp(f, 180, 2000)

        tone = sine_tone(f, dur_s, volume)
        silence = np.zeros(int(FS * gap_s), dtype=np.float32)

        # Evita de tocar partes novamente 
        parts.append(tone)
        parts.append(silence)

    #Guarda o som gerado
    return np.concatenate(parts)

# tem o objetivo de descobrir a frequência principal presente em um trecho de áudio
def dominant_freq(signal):
    N = len(signal)

    #rfft(signal) → aplica a FFT (Transformada Rápida de Fourier). transforma tempo em frequência
    yf = np.abs(rfft(signal))
    xf = rfftfreq(N, 1 / FS)

    idx = np.argmax(yf)
    return xf[idx]

#Converte uma frequência em um dígito hexadecimal 
def freq_to_hex(freq, base_freq):
    # calcula diferença em semitons
    semitones = round(12 * np.log2(freq / base_freq))

    value = semitones + 6  # inverso do v - 6
    value = clamp(value, 0, 15) #protege contra ruído e deixa mais harmônico

    return format(int(value), 'X')

# Transforma um áudio inteiro em string hexadecimal 
def decode_audio(audio, dur, gap):
    # block: número de amostras de uma nota
    # silence: número de amostras da pausa
    
    block = int(dur * FS)
    silence = int(gap * FS)

    pos = 0
    i = 0
    decoded = []

    while pos + block < len(audio):

        #Extrai um bloco de nota e descobre a frequência dominante dessa nota
        chunk = audio[pos:pos + block]
        freq = dominant_freq(chunk)

        #Usando a base de 5 notas
        base = THEME_5[i % 5]
        decoded.append(freq_to_hex(freq, base))

        pos += block + silence
        i += 1

    #Depois unindo todos em uma string hexa
    return ''.join(decoded)

#Grava o som no microfone 
def record_audio(seconds):
    rec = sd.rec(int(seconds * FS), samplerate=FS, channels=1, dtype=np.float32)
    
    #Espera a gravação terminar
    sd.wait()
    return rec.flatten()

#Interface gráfica
class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Lab 1 Prof. Nuncio — Hex para Música")
        self.geometry("540x260")
        self.resizable(False, False)

        frm = ttk.Frame(self, padding=14)
        frm.pack(fill="both", expand=True)

        ttk.Label(frm, text="Código Hexadecimal:", font=("Segoe UI", 11)).grid(row=0, column=0, sticky="w")
        self.hex_var = tk.StringVar(value="19BFCBF")#15F1E1B
        self.entry = ttk.Entry(frm, textvariable=self.hex_var, width=42, font=("Consolas", 14))
        self.entry.grid(row=1, column=0, columnspan=3, sticky="we", pady=(6, 10))
        self.entry.focus_set()

        # Controles
        ttk.Label(frm, text="Duração nota (ms):").grid(row=2, column=0, sticky="w")
        ttk.Label(frm, text="Pausa (ms):").grid(row=3, column=0, sticky="w")
        ttk.Label(frm, text="Volume (0.05–1.0):").grid(row=4, column=0, sticky="w")

        self.dur_var = tk.IntVar(value=600)
        self.gap_var = tk.IntVar(value=80)
        self.vol_var = tk.DoubleVar(value=0.35)

        ttk.Spinbox(frm, from_=80, to=1200, increment=10, textvariable=self.dur_var, width=10).grid(row=2, column=1, sticky="w")
        ttk.Spinbox(frm, from_=0, to=800, increment=10, textvariable=self.gap_var, width=10).grid(row=3, column=1, sticky="w")
        ttk.Spinbox(frm, from_=0.05, to=1.0, increment=0.05, textvariable=self.vol_var, width=10).grid(row=4, column=1, sticky="w")

        btns = ttk.Frame(frm)
        btns.grid(row=5, column=0, columnspan=3, pady=(14, 0), sticky="we")

        ttk.Button(btns, text="Tema (5 notas)", command=self.on_theme).pack(side="left", padx=(0, 10))
        ttk.Button(btns, text="Tocar código HEX", command=self.on_play_hex).pack(side="left", padx=(0, 10))
        ttk.Button(btns, text="Limpar", command=self.on_clear).pack(side="left", padx=(0, 10))
        
        #Botão para gerar arquivo WAV que chamará option_get onde poderemos converter esses som em arquivo WAV
        ttk.Button(btns, text="Gerar arquivo WAV", command=self.wav).pack(side="left", padx=(0, 10))

        #Botão para usar o microfone 
        ttk.Button(btns, text="Usar microfone", command=self.microfone).pack(side="left")


        self.status = tk.StringVar(value="Pronto.")
        ttk.Label(frm, textvariable=self.status).grid(row=6, column=0, columnspan=3, sticky="w", pady=(12, 0))

        frm.columnconfigure(0, weight=1)

        # Enter toca o HEX
        self.bind("<Return>", lambda e: self.on_play_hex())

    def _get_params(self):
        dur_s = self.dur_var.get() / 1000.0
        gap_s = self.gap_var.get() / 1000.0
        vol = clamp(float(self.vol_var.get()), 0.05, 1.0)
        return dur_s, gap_s, vol

    def on_theme(self):
        dur_s, gap_s, vol = self._get_params()
        play_theme_5(dur_s, gap_s, vol)

    def on_play_hex(self):
        dur_s, gap_s, vol = self._get_params()
        play_hex_as_close_encounters(self.hex_var.get(), dur_s, gap_s, vol)

    def on_clear(self):
        self.hex_var.set("")
        self.entry.focus_set()

    # configurar para "pegar o arquivo" e converter para WAV
    def wav(self):
        try:
            # número hexadecimal convertido em RA(decimal)
            RA =  int(self.hex_var.get(), 16)
            dur_s, gap_s, vol = self._get_params()
            hx = self.hex_var.get()

            #pega o áudio gravado e transforma em formato de padrão de WAV
            audio_np = hex_to_audio_array(hx, dur_s, gap_s, vol)
            audio_int16 = np.int16(audio_np * 32767)

            #Tranforma para um áudio de verdade 
            audio = AudioSegment(
                audio_int16.tobytes(),
                frame_rate=FS,
                sample_width=2,
                channels=1
            )

            #Transforma em um formato WAV 
            filename = f"RA_{RA}.wav"
            audio.export(filename, format="wav")

            #Notificação do download do áudio
            messagebox.showinfo("Sucesso", f"Arquivo WAV gerado:\n{filename}")

        #Exceção caso não consiga converter o som
        except Exception as ex:
            messagebox.showerror("Erro", str(ex))

    #Botão do microfone 
    def microfone(self):
        try:
            #a função tenta pegar a parte do som 
            dur_s, gap_s, _ = self._get_params()

            #Apresenta o status de gravação na interface de baixo
            self.status.set("Gravando áudio (5s)...")
            self.update()

            #grava o áudio recebido para ser repoduzido novamente
            audio = record_audio(5)
            hx = decode_audio(audio, dur_s, gap_s)

            #Aviso de recebimento e atualizaççao dos status
            self.status.set(f"HEX recebido: {hx}")
            self.hex_var.set(hx)

        except Exception as e:
            messagebox.showerror("Erro no microfone", str(e))

